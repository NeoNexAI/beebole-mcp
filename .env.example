# Solo para el modo LOCAL (stdio). NUNCA commitear el .env real.
# La API key se obtiene en app.beebole.com › Settings › API.
BEEBOLE_API_KEY=pon-aqui-tu-api-key-de-beebole

# Opcional: sobrescribir el endpoint GraphQL (por defecto https://app.beebole.com/graphql).
# BEEBOLE_GRAPHQL_ENDPOINT=https://app.beebole.com/graphql

# Solo para el modo HTTP (VPS): el token NO va aquí, viaja por cabecera X-Beebole-Key.
# MCP_TRANSPORT=http
# PORT=8087
