{
  "name": "@neonexai/beebole-mcp",
  "version": "0.1.0",
  "description": "MCP server para Beebole (control de horas) — NeoNexAI. Transportes: stdio (local, recomendado) + Streamable HTTP (remoto en VPS).",
  "type": "module",
  "bin": {
    "beebole-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/smoke.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeoNexAI/beebole-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
